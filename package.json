{
  "name": "scraaaper-desktop",
  "version": "0.4.0",
  "description": "Ricerca libri e documenti in cataloghi e archivi online su macOS e Windows",
  "main": "desktop/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/rasoipress/Scraaaper.git"
  },
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "build:engine": "node scripts/build-engine.mjs",
    "dist:mac": "pnpm run build:engine && electron-builder --mac dmg zip --publish never",
    "dist:mac:x64": "pnpm run build:engine && electron-builder --mac dmg zip --x64 --publish never",
    "dist:mac:arm64": "pnpm run build:engine && electron-builder --mac dmg zip --arm64 --publish never",
    "dist:win": "pnpm run build:engine && electron-builder --win nsis zip --x64 --publish never"
  },
  "packageManager": "pnpm@11.9.0",
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "app.scraaaper.desktop",
    "productName": "Scraaaper",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "electronDownload": {
      "cache": "work/electron-cache"
    },
    "files": [
      "desktop/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-bin/scraaaper-search-service",
        "to": "search-service"
      }
    ],
    "artifactName": "Scraaaper-${version}-${os}-${arch}.${ext}",
    "mac": {
      "icon": "build/icon.svg",
      "category": "public.app-category.reference",
      "identity": null,
      "hardenedRuntime": false,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "Scraaaper ${version}",
      "contents": [
        {
          "x": 140,
          "y": 210
        },
        {
          "x": 400,
          "y": 210,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "build/icon",
      "signExecutable": false,
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Scraaaper",
      "uninstallDisplayName": "Scraaaper"
    }
  }
}
